# ── Itrawala environment ───────────────────────────────────────────────
# Copy this file to ".env" (local dev) and also set these in your Vercel project's
# Environment Variables (Project → Settings → Environment Variables) for production.
# Every integration is already wired in code — it activates the moment a real value
# is present. Restart `npm run dev` / redeploy after editing.

# ── Supabase (auth + orders + lead/subscriber storage) ──
# Settings → API in your Supabase project.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Settings → API → "service_role" secret key. SERVER-ONLY — do NOT prefix with VITE_,
# and never expose this in client code. Used by /api functions to auto-create an
# account for every order and to write to the `orders` table (see supabase-tables.sql).
SUPABASE_SERVICE_ROLE_KEY=

# ── PayU (payment gateway) — SERVER-ONLY, prepaid checkout, no COD ──
# From your PayU Dashboard → Settings → Merchant Key & Salt.
# Leave both blank to keep checkout in "not configured yet" mode (it shows a friendly
# error instead of charging anyone). Add real values to go live.
PAYU_MERCHANT_KEY=
PAYU_SALT=
# "test" uses https://test.payu.in (PayU's sandbox — use PayU's test cards/UPI to try
# a full checkout). Switch to "production" only once PAYU_MERCHANT_KEY/PAYU_SALT are
# your LIVE (not test) credentials.
PAYU_MODE=test
# Optional: force a specific origin for PayU success/failure redirects instead of
# auto-detecting it from the request (useful with custom domains / preview URLs).
SITE_URL=

# ── Resend (order confirmation emails) — SERVER-ONLY, optional ──
# Create a free account at resend.com, verify a sending domain (or use their shared
# test domain while developing), then grab an API key from Dashboard → API Keys.
# Leave blank to skip emails entirely — checkout still works either way.
RESEND_API_KEY=
# Must be on the domain you verified in Resend, e.g. "Itrawala <orders@itrawala.in>".
RESEND_FROM_EMAIL=

# Business / legal (shown in footer, policies, trust sections)
VITE_GST=
VITE_BUSINESS_ADDRESS=
VITE_SUPPORT_EMAIL=
VITE_SUPPORT_PHONE=

# Integrations — drop a value to go live
VITE_WHATSAPP_NUMBER=        # digits only, country code first, e.g. 917014657175
VITE_AMAZON_STORE_URL=       # full https URL to your Amazon storefront
VITE_INSTAGRAM_HANDLE=       # without the @, e.g. itrawalaa
VITE_FACEBOOK_HANDLE=        # facebook.com/<handle>, e.g. theitrawala
VITE_HERO_VIDEO_URL=         # mp4 URL for the homepage hero background (optional)
